{
  "name": "moody",
  "version": "0.1.0",
  "description": "Moodboard desktop app",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron:dev": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && electron .\"",
    "electron:build": "ng build --base-href ./ && electron-builder --win",
    "electron:build:dir": "ng build --base-href ./ && electron-builder --win --dir"
  },
  "main": "electron/main.js",
  "private": true,
  "build": {
    "appId": "com.moody.app",
    "productName": "Moody",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/front/browser/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../config",
        "to": "config"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "public/icon.png"
    }
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "jszip": "^3.10.1",
    "konva": "^10.2.0",
    "ng2-konva": "^12.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.4"
  }
}
