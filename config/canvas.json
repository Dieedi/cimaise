{
    "image": {
        "duplicateOffset": 20
    },
    "viewport": {
        "focusAllPadding": 50
    },
    "imgbb": {
        "padding": 2,
        "bgColor": "#2e2e2e"
    },
    "selection": {
        "borderColor": "#6dffce",
        "borderWidth": 2,
        "boxStroke": "#c9c9c9ad",
        "boxStrokeWidth": 1,
        "boxFill": "#2e2e2ec0",
        "minBoxSize": 5
    },
    "frame": {
        "defaultWidth": 400,
        "defaultHeight": 300,
        "bgColor": "#2a2a2a",
        "bgOpacity": 0.6,
        "borderColor": "#555555",
        "borderWidth": 1,
        "borderHighlightColor": "#888888",
        "cornerRadius": 4,
        "titleBarHeight": 32,
        "titleBarColor": "#353535",
        "titleBarOpacity": 0.8,
        "titleFontSize": 16,
        "titleFontFamily": "Arial",
        "titleColor": "#cccccc",
        "titlePadding": 10,
        "edgeThreshold": 6,
        "contentPadding": 15,
        "minWidth": 100,
        "minHeight": 60,
        "colorPresets": [
            { "name": "Default",  "color": "#2a2a2a" },
            { "name": "Red",      "color": "#7f1d1d" },
            { "name": "Orange",   "color": "#7c2d12" },
            { "name": "Yellow",   "color": "#713f12" },
            { "name": "Green",    "color": "#14532d" },
            { "name": "Teal",     "color": "#134e4a" },
            { "name": "Blue",     "color": "#1e3a5f" },
            { "name": "Purple",   "color": "#3b0764" },
            { "name": "Pink",     "color": "#831843" }
        ]
    }
}